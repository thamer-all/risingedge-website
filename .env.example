# Rising Edge Community Website Environment Variables

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here

# Production Stripe Keys (use these in production)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key_here
# STRIPE_SECRET_KEY=sk_live_your_live_secret_key_here

# Application Configuration
VITE_APP_NAME=Rising Edge Community
VITE_APP_URL=http://localhost:5174
VITE_API_URL=http://localhost:5174/api

# Contact Form Configuration (if using external service)
VITE_CONTACT_FORM_ENDPOINT=your_contact_form_endpoint_here

# Analytics (optional)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Social Media Links
VITE_FACEBOOK_URL=https://facebook.com/risingedgecommunity
VITE_TWITTER_URL=https://twitter.com/risingedgecommunity
VITE_INSTAGRAM_URL=https://instagram.com/risingedgecommunity
VITE_LINKEDIN_URL=https://linkedin.com/company/risingedgecommunity
